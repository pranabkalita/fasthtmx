# =========================
# Application
# =========================
APP_NAME=FastAuth
APP_URL=http://localhost:8000
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-characters

# =========================
# MySQL Database
# =========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fastauth
DB_USER=root
DB_PASSWORD=password

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =========================
# Session
# =========================
SESSION_COOKIE_NAME=session_id
SESSION_MAX_AGE=604800

# =========================
# Email (SMTP)
# =========================
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@localhost
MAIL_FROM_NAME=FastAuth
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# =========================
# Rate Limiting
# =========================
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# =========================
# Account Lifecycle
# =========================
ACCOUNT_PURGE_DAYS=30
