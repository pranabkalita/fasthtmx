# =========================
# Application
# =========================
APP_NAME=FastAuth
APP_URL=http://localhost:8000
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-characters

# =========================
# MySQL Database
# =========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fastauth
DB_USER=root
DB_PASSWORD=password

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =========================
# Session
# =========================
SESSION_COOKIE_NAME=session_id
SESSION_MAX_AGE=604800
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ABSOLUTE_TIMEOUT_SECONDS=43200
SESSION_RENEWAL_THRESHOLD_SECONDS=300
REMEMBER_ME_ENABLED=false
REMEMBER_ME_IDLE_TIMEOUT_SECONDS=86400
REMEMBER_ME_ABSOLUTE_TIMEOUT_SECONDS=604800
STEP_UP_WINDOW_SECONDS=900
RESET_TOKEN_EXPIRY_MINUTES=30

# =========================
# Email (SMTP)
# =========================
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@localhost
MAIL_FROM_NAME=FastAuth
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# =========================
# Rate Limiting
# =========================
LOGIN_MAX_ATTEMPTS=5
LOGIN_MAX_ATTEMPTS_PER_IP=5
LOGIN_MAX_ATTEMPTS_ACCOUNT_WINDOW=20
LOGIN_LOCKOUT_MINUTES=15

# =========================
# Account Lifecycle
# =========================
ACCOUNT_PURGE_DAYS=30
USE_FORWARDED_HEADERS=false
TRUSTED_PROXY_IPS=
CSP_ENABLED=true
CSP_REPORT_ONLY=false
